#!/bin/bash
# Pre-commit hook pour incrémenter automatiquement la version des blueprints modifiés
# Compatible Windows (Git Bash), Linux et Mac

# Récupérer les fichiers stagés
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$staged_files" ]; then
    exit 0
fi

modified_files=()

for file in $staged_files; do
    # Vérifier si c'est un blueprint
    if [[ $file =~ ^blueprints/automation/.+\.yaml$ ]] && [ -f "$file" ]; then
        # Lire la version actuelle (commentaire en haut du fichier)
        if grep -q "^# Version:" "$file"; then
            current_version=$(grep "^# Version:" "$file" | sed -E 's/^# Version:\s*([0-9]+\.[0-9]+\.[0-9]+)/\1/')
            major=$(echo "$current_version" | cut -d. -f1)
            minor=$(echo "$current_version" | cut -d. -f2)
            patch=$(echo "$current_version" | cut -d. -f3)

            # Incrémenter le patch
            patch=$((patch + 1))
            new_version="$major.$minor.$patch"

            # Remplacer la version dans le commentaire (première ligne)
            sed -i.bak -E "s/^# Version:\s*[0-9]+\.[0-9]+\.[0-9]+/# Version: $new_version/" "$file"

            # Remplacer la version dans la description du blueprint
            sed -i.bak -E "s/(description:\s*>\s*\n\s*)Version:\s*[0-9]+\.[0-9]+\.[0-9]+/\1Version: $new_version/" "$file"

            rm -f "$file.bak"
        else
            # Ajouter la version en première ligne
            new_version="1.0.0"
            current_version="NOUVEAU"

            # Insérer la version au début du fichier
            sed -i.bak "1i\\
# Version: $new_version" "$file"

            # Ajouter également dans la description
            sed -i.bak -E "s/(description:\s*>\s*\n)/\1    Version: $new_version\n/" "$file"

            rm -f "$file.bak"
        fi

        # Ajouter le fichier modifié au commit
        git add "$file"

        modified_files+=("$file: $current_version → $new_version")
        echo "✓ Version mise à jour : $file"
    fi
done

if [ ${#modified_files[@]} -gt 0 ]; then
    echo ""
    echo "📦 Versions automatiquement incrémentées :"
    for msg in "${modified_files[@]}"; do
        echo "  • $msg"
    done
fi

exit 0

